# ── Database (NeonDB / PostgreSQL) ──────────────────────────────
# Pooled connection (pgbouncer) — used by the app at runtime
DATABASE_URL="postgres://user:pass@ep-xxxx-pooler.region.aws.neon.tech/aurum?sslmode=require"
# ── Auth.js ──────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace_with_random_base64_32bytes"
AUTH_URL="http://localhost:3000"

# ── Credential encryption (WordPress app passwords) ─────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace_with_64_hex_chars"

# ── Cloudflare R2 (S3-compatible object storage: images / thumbnails) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="aurum-media"
R2_PUBLIC_HOSTNAME="media.example.com"      # custom domain or r2.dev hostname
NEXT_PUBLIC_R2_PUBLIC_URL="https://media.example.com"

# ── Bunny.net Stream (video: upload + transcode + HLS delivery) ──
BUNNY_LIBRARY_ID=""
BUNNY_API_KEY=""
BUNNY_CDN_HOST="vz-aurum.b-cdn.net"

# ── Rate limiting (Upstash Redis, optional — falls back to in-memory in dev) ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Misc ─────────────────────────────────────────────────────────
NODE_ENV="development"
