# ── Database (NeonDB / PostgreSQL) ──────────────────────────────
# Pooled connection (pgbouncer) — used by the app at runtime
DATABASE_URL="postgres://user:pass@pooled.db.prisma.io:5432/postgres?sslmode=require"

# ── Auth.js ──────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace_with_random_base64_32bytes"
AUTH_URL="http://localhost:3000"

# ── Credential encryption (WordPress app passwords) ─────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace_with_64_hex_chars"

# ── Cloudflare R2 (S3-compatible object storage: images / thumbnails / preview clips / source video) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="aurum-media"
R2_PUBLIC_HOSTNAME="media.example.com"      # custom domain or r2.dev hostname
NEXT_PUBLIC_R2_PUBLIC_URL="https://media.example.com"

# ── JWPlayer (primary playback + automated ingest) ──
# Store JWPlayer API credentials/player ID/site ID in Admin → Player, not in .env.
# Upload flow: browser uploads the source video straight to R2, then the
# server calls the JWX Management API's fetch-upload ingest
# (https://api.jwplayer.com/v2/sites/{site_id}/media/) using the R2 URL.
# JWPlayer returns a Media ID; AURUM stores it and generates:
# https://cdn.jwplayer.com/players/{mediaId}-{playerId}.html
# Requires, per PlayerConfig row: playerId, API Secret (V2, used as Bearer
# token), and Site/Property ID (stored in extraConfig.siteId).

# ── Bunny.net Stream (optional legacy/fallback video upload path) ──
BUNNY_LIBRARY_ID=""
BUNNY_API_KEY=""
BUNNY_CDN_HOST="vz-aurum.b-cdn.net"

# ── Rate limiting (Upstash Redis, optional — falls back to in-memory in dev) ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Misc ─────────────────────────────────────────────────────────
NODE_ENV="development"
