{
  "name": "aurum-project",
  "version": "2.0.0",
  "private": true,
  "description": "AURUM — multi-site content distribution platform (Next.js / Prisma / NeonDB / Cloudflare R2)",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:player": "node scripts/build-aurum-player.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "categories:seed": "tsx scripts/seed-categories.ts",
    "admin:check-login": "tsx scripts/check-admin-login.ts",
    "admin:check-http-login": "tsx scripts/check-admin-http-login.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.687.0",
    "@prisma/client": "^6.1.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "hls.js": "^1.5.17",
    "next": "^15.1.0",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tus-js-client": "^4.3.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
