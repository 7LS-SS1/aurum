generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STAFF
  SENIOR
  MANAGER
  HEAD
  SYSTEM
}

enum SiteAuthType {
  APP_PASSWORD
  JWT
}

enum SiteHealth {
  OK
  ERROR
  UNKNOWN
}

enum MovieStatus {
  DRAFT
  READY_FOR_REVIEW
  IN_REVIEW
  REJECTED
  READY_FOR_APPROVAL
  APPROVED
  PUBLISHING
  DONE
  PARTIAL
  FAILED
  ARCHIVED
}

enum DistributionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum ReactionType {
  LIKE
  DISLIKE
}

/// Admin/editor accounts — every mutating API call is tied to one of these.
/// SYSTEM is never used for interactive login; automation authenticates via
/// the X-System-Key header instead (see src/lib/authz.ts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdMovies  Movie[]    @relation("MovieCreatedBy")
  reviewedMovies Movie[]    @relation("MovieReviewer")
  auditLogs      AuditLog[]
  wordpressThemes WordpressTheme[] @relation("WordpressThemeCreatedBy")

  @@map("users")
}

/// Master content record — uploaded once, video_url is shared by every
/// distribution. Per-site text/metadata overrides live in MovieSiteDraft.
model Movie {
  id              String      @id @default(cuid())
  title           String
  slug            String?     @unique
  excerpt         String?
  content         String?
  mainCategory    String?     @map("main_category")
  categories      Json        @default("[]")
  tags            Json        @default("[]")
  thumbnailUrl    String?     @map("thumbnail_url")
  previewUrl      String?     @map("preview_url")
  iframeUrl       String?     @map("iframe_url")
  videoUrl        String?     @map("video_url")
  videoProvider   String?     @map("video_provider")
  jwPlayerMediaId String?     @map("jwplayer_media_id")
  extraMeta       Json        @default("{}") @map("extra_meta")
  targetSiteIds   Json        @default("[]") @map("target_site_ids")
  viewCount       Int         @default(0) @map("view_count")
  status          MovieStatus @default(DRAFT)
  rejectionReason String?     @map("rejection_reason")
  createdById     String?     @map("created_by_id")
  reviewerId      String?     @map("reviewer_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  createdBy User? @relation("MovieCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reviewer  User? @relation("MovieReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  siteDrafts    MovieSiteDraft[]
  distributions Distribution[]
  reactions     MovieReaction[]
  watchLaters   WatchLater[]
  comments      Comment[]

  @@index([status])
  @@index([mainCategory])
  @@index([createdAt])
  @@index([createdById])
  @@map("movies")
}

/// Destination WordPress site. Credentials are always AES-256-GCM encrypted
/// (see src/lib/crypto.ts) — plaintext never touches the database.
model TargetSite {
  id                String       @id @default(cuid())
  name              String
  baseUrl           String       @map("base_url")
  authType          SiteAuthType @default(APP_PASSWORD) @map("auth_type")
  wpUsername        String?      @map("wp_username")
  credentialEnc     String       @map("credential_enc")
  credentialIv      String       @map("credential_iv")
  credentialTag     String       @map("credential_tag")
  postType          String       @default("posts") @map("post_type")
  categoryRestBase  String       @default("categories") @map("category_rest_base")
  tagRestBase       String       @default("tags") @map("tag_rest_base")
  defaultStatus     String       @default("publish") @map("default_status")
  isActive          Boolean      @default(true) @map("is_active")
  healthStatus      SiteHealth   @default(UNKNOWN) @map("health_status")
  lastCheckedAt     DateTime?    @map("last_checked_at")
  createdAt         DateTime     @default(now()) @map("created_at")

  siteDrafts    MovieSiteDraft[]
  distributions Distribution[]

  @@map("target_sites")
}

/// Per-(movie, site) content override. Any null field falls back to the
/// parent Movie's value when the distribution payload is built — the video
/// itself is never overridden here, it always comes from Movie.videoUrl.
model MovieSiteDraft {
  id         String   @id @default(cuid())
  movieId    String   @map("movie_id")
  siteId     String   @map("site_id")
  title      String?
  slug       String?
  excerpt    String?
  content    String?
  categories Json?
  tags       Json?
  extraMeta  Json?    @map("extra_meta")
  status     String   @default("draft")
  updatedAt  DateTime @updatedAt @map("updated_at")

  movie Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  site  TargetSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([movieId, siteId])
  @@map("movie_site_drafts")
}

/// Per-(movie, site) distribution status/history. Idempotent — one row per
/// pair, updated in place on retry so it also doubles as an audit trail.
model Distribution {
  id            String             @id @default(cuid())
  movieId       String             @map("movie_id")
  siteId        String             @map("site_id")
  status        DistributionStatus @default(PENDING)
  remotePostId  String?            @map("remote_post_id")
  remotePostUrl String?            @map("remote_post_url")
  errorMessage  String?            @map("error_message")
  attempts      Int                @default(0)
  distributedAt DateTime?          @map("distributed_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  movie Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  site  TargetSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([movieId, siteId])
  @@index([movieId])
  @@index([siteId])
  @@index([status])
  @@map("distributions")
}

/// Immutable trail of every sensitive admin action — who did what to which
/// resource. actorId is nullable/SetNull because SYSTEM-role calls (internal
/// automation via X-System-Key) have no backing User row.
model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?  @map("actor_id")
  actorRole    Role     @map("actor_role")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([actorId])
  @@map("audit_logs")
}

/// Media player (JWPlayer) configuration. apiKey/apiSecret are always
/// AES-256-GCM encrypted (see src/lib/crypto.ts) — same pattern as
/// TargetSite credentials, plaintext never touches the database.
model PlayerConfig {
  id                String   @id @default(cuid())
  provider          String   @default("JWPLAYER")
  name              String
  playerId          String   @map("player_id")
  libraryUrl        String?  @map("library_url")
  apiKeyEnc         String   @map("api_key_enc")
  apiKeyIv          String   @map("api_key_iv")
  apiKeyTag         String   @map("api_key_tag")
  apiSecretEnc      String?  @map("api_secret_enc")
  apiSecretIv       String?  @map("api_secret_iv")
  apiSecretTag      String?  @map("api_secret_tag")
  defaultPosterMode String   @default("auto") @map("default_poster_mode")
  isDefault         Boolean  @default(false) @map("is_default")
  isActive          Boolean  @default(true) @map("is_active")
  extraConfig       Json     @default("{}") @map("extra_config")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("player_configs")
}

model WordpressTheme {
  id            String   @id @default(cuid())
  name          String
  slug          String
  version       String
  description   String?
  packageUrl    String   @map("package_url")
  packageSize   Int?     @map("package_size")
  screenshotUrl String?  @map("screenshot_url")
  changelog     String?
  isActive      Boolean  @default(true) @map("is_active")
  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdBy User? @relation("WordpressThemeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([slug, version])
  @@index([slug, isActive])
  @@index([createdAt])
  @@map("wordpress_themes")
}

/// Public viewer account — a separate identity system from staff `User`.
/// Never touches NextAuth/Role; sessions are opaque hashed-token cookies
/// (see src/lib/viewer-auth.ts), not JWTs.
model Viewer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions    ViewerSession[]
  reactions   MovieReaction[]
  watchLaters WatchLater[]
  comments    Comment[]

  @@map("viewers")
}

/// One row per active login. The raw token is never stored — only its
/// SHA-256 hash — since it's 256 bits of real randomness (unlike a human
/// password) a fast one-way hash is enough; this is not the AES envelope
/// pattern in src/lib/crypto.ts, which exists for secrets we must later
/// decrypt back to plaintext, which a session token never needs.
model ViewerSession {
  id        String   @id @default(cuid())
  viewerId  String   @map("viewer_id")
  tokenHash String   @unique @map("token_hash")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  viewer Viewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([viewerId])
  @@index([expiresAt])
  @@map("viewer_sessions")
}

/// Like/dislike — one row per (movie, viewer); toggling flips/deletes the
/// row in place, mirroring Distribution's upsert-in-place idempotency.
model MovieReaction {
  id        String       @id @default(cuid())
  movieId   String       @map("movie_id")
  viewerId  String       @map("viewer_id")
  type      ReactionType
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  viewer Viewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([movieId, viewerId])
  @@index([movieId, type])
  @@map("movie_reactions")
}

/// "Watch later" save list — presence of a row = saved.
model WatchLater {
  id        String   @id @default(cuid())
  movieId   String   @map("movie_id")
  viewerId  String   @map("viewer_id")
  createdAt DateTime @default(now()) @map("created_at")

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  viewer Viewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([movieId, viewerId])
  @@index([viewerId])
  @@map("watch_laters")
}

/// Flat viewer comments — no moderation queue/reply-threading in this phase.
model Comment {
  id        String   @id @default(cuid())
  movieId   String   @map("movie_id")
  viewerId  String   @map("viewer_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  viewer Viewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([movieId, createdAt])
  @@index([viewerId])
  @@map("comments")
}
